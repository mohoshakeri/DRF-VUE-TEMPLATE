SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Normal Management Commands
0 2 * * * cd /app && PROCESS_TYPE=cron python manage.py run_cron_job command cleanup_orphan_files >> /var/log/project/cron.log 2>&1

