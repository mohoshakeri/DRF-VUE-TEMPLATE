# 0 3 * * * cd /app && PROCESS_TYPE=cron python manage.py run_cron_job celery "EXAMPLE" >> /var/log/project/cron.log 2>&1

# Repeat Tasks
# 0 0,15,30,45 * * * cd /app && PROCESS_TYPE=cron python manage.py run_cron_job celery "EXAMPLE" >> /var/log/project/cron.log 2>&1